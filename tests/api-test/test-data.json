  "validationRules": {
    "required_fields": {
      "dashboard": ["id", "dashboard_title", "url"],
      "chart": ["id", "slice_name", "viz_type"],
      "dataset": ["id", "table_name", "database"],
      "database": ["id", "database_name", "sqlalchemy_uri_decrypted"],
      "user": ["username", "email", "roles"],
      "role": ["id", "name"]
    },
    "data_types": {
      "id": "number",
      "published": "boolean",
      "created_on": "string",
      "changed_on": "string"
    },
    "response_structures": {
      "list_response": ["count", "result"],
      "single_response": ["result"],
      "error_response": ["message"]
    }
  },
