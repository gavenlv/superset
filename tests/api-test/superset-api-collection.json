{
  "info": {
    "name": "Superset API Complete Test Suite",
    "description": "Complete API test collection for Apache Superset with authentication, CRUD operations, and response validation",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8088",
      "description": "Superset server base URL"
    },
    {
      "key": "accessToken",
      "value": "",
      "description": "JWT access token for authentication"
    },
    {
      "key": "refreshToken",
      "value": "",
      "description": "Refresh token"
    },
    {
      "key": "csrfToken",
      "value": "",
      "description": "CSRF token for security"
    },
    {
      "key": "username",
      "value": "admin",
      "description": "Username for login"
    },
    {
      "key": "password",
      "value": "admin",
      "description": "Password for login"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01. Authentication",
      "description": "Authentication and authorization endpoints",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"provider\": \"db\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/security/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "security", "login"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test response status",
                  "pm.test('Login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test response structure",
                  "pm.test('Response has access token', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('access_token');",
                  "    pm.expect(responseJson.access_token).to.be.a('string');",
                  "    pm.expect(responseJson.access_token).to.not.be.empty;",
                  "});",
                  "",
                  "// Save tokens to variables",
                  "pm.test('Save tokens', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', responseJson.access_token);",
                  "    if (responseJson.refresh_token) {",
                  "        pm.collectionVariables.set('refreshToken', responseJson.refresh_token);",
                  "    }",
                  "});",
                  "",
                  "// Validate token format (JWT)",
                  "pm.test('Access token is valid JWT format', function () {",
                  "    const responseJson = pm.response.json();",
                  "    const token = responseJson.access_token;",
                  "    const tokenParts = token.split('.');",
                  "    pm.expect(tokenParts).to.have.lengthOf(3);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/me/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User info retrieved successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains user data', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('result');",
                  "    pm.expect(responseJson.result).to.have.property('username');",
                  "    pm.expect(responseJson.result).to.have.property('email');",
                  "    pm.expect(responseJson.result).to.have.property('roles');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "CSRF Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/security/csrf_token/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "security", "csrf_token"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('CSRF token retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Save CSRF token', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.result) {",
                  "        pm.collectionVariables.set('csrfToken', responseJson.result);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02. Dashboards",
      "description": "Dashboard management endpoints",
      "item": [
        {
          "name": "List Dashboards",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/dashboard/?q=(page:0,page_size:25)",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dashboard"],
              "query": [
                {
                  "key": "q",
                  "value": "(page:0,page_size:25)"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Dashboards retrieved successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response structure is valid', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('count');",
                  "    pm.expect(responseJson).to.have.property('result');",
                  "    pm.expect(responseJson.result).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Dashboard objects have required fields', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.result.length > 0) {",
                  "        const dashboard = responseJson.result[0];",
                  "        pm.expect(dashboard).to.have.property('id');",
                  "        pm.expect(dashboard).to.have.property('dashboard_title');",
                  "        pm.expect(dashboard).to.have.property('url');",
                  "        pm.expect(dashboard).to.have.property('published');",
                  "    }",
                  "});",
                  "",
                  "// Save first dashboard ID for further tests",
                  "pm.test('Save dashboard ID', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.result.length > 0) {",
                  "        pm.collectionVariables.set('dashboardId', responseJson.result[0].id);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Dashboard by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/dashboard/{{dashboardId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dashboard", "{{dashboardId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Dashboard details retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Dashboard has complete data', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('result');",
                  "    const dashboard = responseJson.result;",
                  "    pm.expect(dashboard).to.have.property('dashboard_title');",
                  "    pm.expect(dashboard).to.have.property('position_json');",
                  "    pm.expect(dashboard).to.have.property('metadata');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
